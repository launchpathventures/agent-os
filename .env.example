# Ditto — Environment Variables

# Database
# SQLite — auto-created at data/ditto.db. No configuration needed.
# Schema is synced automatically via `pnpm cli sync`.

# ============================================================
# LLM Provider (required — no default)
# ============================================================
# Choose one provider and model. Ditto works with any of these:

# Option 1: Anthropic (Claude)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Option 3: Ollama (local, free)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.3
# OLLAMA_URL=http://localhost:11434

# ============================================================
# Dev Pipeline — Telegram Bot (optional)
# ============================================================
# Create a bot via @BotFather on Telegram, get the token
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
